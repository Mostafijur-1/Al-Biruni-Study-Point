# Copy to .env.local for development. Add the same keys in Vercel → Project → Settings → Environment Variables.

# Database (MongoDB Atlas — allow 0.0.0.0/0 or Vercel IPs for serverless)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/absp

# JWT (use long random strings, min 32 characters each)
JWT_ACCESS_SECRET=replace_with_minimum_32_characters_secret
JWT_REFRESH_SECRET=replace_with_another_32_characters_secret
JWT_ACCESS_EXPIRES=365d
JWT_REFRESH_EXPIRES=3650d

# Cloudinary (optional — CQ image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App URL (production: your Vercel domain, e.g. https://absp.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=bn

# LLM (OpenRouter & Gemini configurations)
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
